{
  "info": {
    "name": "fiap-soat-execution-service",
    "description": "Execution and Production microservice — FIFO queues for diagnosis and repair execution.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3002" },
    { "key": "serviceOrderId", "value": "11111111-1111-1111-1111-111111111111" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Get diagnosis queue",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/queues/diagnosis"
      }
    },
    {
      "name": "Get execution queue",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/queues/execution"
      }
    },
    {
      "name": "Get execution order",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/executions/{{serviceOrderId}}"
      }
    },
    {
      "name": "Start repair (head of queue only)",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/executions/{{serviceOrderId}}/start"
      }
    },
    {
      "name": "Finish repair (publishes execution.finished)",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/executions/{{serviceOrderId}}/finish"
      }
    },
    {
      "name": "Fail repair (publishes execution.failed)",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Peça indisponível no estoque\"\n}"
        },
        "url": "{{baseUrl}}/api/executions/{{serviceOrderId}}/fail"
      }
    }
  ]
}
